    document.getElementById('cd-h').textContent=pad(~~(t/3600));
    document.getElementById('cd-m').textContent=pad(~~((t%3600)/60));
    document.getElementById('cd-s').textContent=pad(t%60);
    t--;
  }
  tick(); setInterval(tick,1000);
})();

// COUNTERS
function animCount(el,target,ms){
  let v=0,step=target/(ms/16);
  const timer=setInterval(()=>{
    v=Math.min(v+step,target);
    el.textContent=Math.round(v).toLocaleString('pt-BR');
    if(v>=target)clearInterval(timer);
  },16);
}
const statObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      const c1=document.getElementById('cnt1');
      const c2=document.getElementById('cnt2');
      if(c1&&!c1.done){c1.done=1;animCount(c1,12847,2000);}
      if(c2&&!c2.done){c2.done=1;animCount(c2,312,1600);}
    }
  });
},{threshold:0.3});
const sr=document.querySelector('.stats-section');
if(sr) statObs.observe(sr);

