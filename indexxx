<script>
function abrirModal() {
  const m = document.getElementById('pixModal');
  m.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function fecharModal() {
  const m = document.getElementById('pixModal');
  m.style.display = 'none';
  document.body.style.overflow = '';
  // reset
  document.getElementById('step1').style.display = 'block';
  document.getElementById('step2').style.display = 'none';
  document.getElementById('erroMsg').style.display = 'none';
  document.getElementById('payerName').value = '';
  document.getElementById('payerCPF').value = '';
  clearInterval(window._pixTimer);
}
function mascaraCPF(el) {
  let v = el.value.replace(/\D/g,'');
  if(v.length > 11) v = v.slice(0,11);
  v = v.replace(/(\d{3})(\d)/,'$1.$2');
  v = v.replace(/(\d{3})(\d)/,'$1.$2');
  v = v.replace(/(\d{3})(\d{1,2})$/,'$1-$2');
  el.value = v;
}
function copiarPix() {
  const input = document.getElementById('copyPasteInput');
  navigator.clipboard.writeText(input.value).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.textContent = '✓ COPIADO';
    btn.style.color = '#4caf50';
    setTimeout(() => { btn.textContent = 'COPIAR'; btn.style.color = ''; }, 2000);
  });
}

let _txId = null;

async function gerarPix() {
  const nome = document.getElementById('payerName').value.trim();
  const cpf = document.getElementById('payerCPF').value.trim();
  const erroEl = document.getElementById('erroMsg');
  erroEl.style.display = 'none';

  if (!nome || nome.length < 3) { erroEl.textContent = '⚠️ Digite seu nome completo'; erroEl.style.display = 'block'; return; }
  if (cpf.replace(/\D/g,'').length !== 11) { erroEl.textContent = '⚠️ CPF inválido'; erroEl.style.display = 'block'; return; }

  const btn = event.target;
  btn.textContent = '⏳ Gerando PIX...';
  btn.disabled = true;

  try {
    const res = await fetch('/criar-pix', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nome, cpf })
    });
    const data = await res.json();

    if (!res.ok) { throw new Error(data.erro || 'Erro ao gerar PIX'); }

    _txId = data.transactionId;
    document.getElementById('qrImg').src = data.qrCodeBase64;
    document.getElementById('copyPasteInput').value = data.copyPaste;

    document.getElementById('step1').style.display = 'none';
    document.getElementById('step2').style.display = 'block';

    // Poll status a cada 5s
    window._pixTimer = setInterval(async () => {
      const r = await fetch('/verificar-pix', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ transactionId: _txId })
      });
      const d = await r.json();
      if (d.status === 'COMPLETO') {
        clearInterval(window._pixTimer);
        document.getElementById('aguardando').style.display = 'none';
        document.getElementById('pagoMsg').style.display = 'block';
      }
    }, 5000);

  } catch(e) {
    erroEl.textContent = '⚠️ ' + e.message;
    erroEl.style.display = 'block';
    btn.textContent = '🔥 GERAR PIX AGORA';
    btn.disabled = false;
  }
}
</script>

